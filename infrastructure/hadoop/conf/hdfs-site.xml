<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- ============================================================ -->
    <!-- HDFS-SITE — Hadoop 3.3.4 Lakehouse Configuration            -->
    <!-- ============================================================ -->

    <!-- Replication — single node for dev -->
    <property>
        <name>dfs.replication</name>
        <value>1</value>
    </property>

    <!-- NameNode storage -->
    <property>
        <name>dfs.namenode.name.dir</name>
        <value>file:///hadoop/dfs/name</value>
    </property>

    <!-- DataNode storage -->
    <property>
        <name>dfs.datanode.data.dir</name>
        <value>file:///hadoop/dfs/data</value>
    </property>

    <!-- NameNode edits -->
    <property>
        <name>dfs.namenode.edits.dir</name>
        <value>file:///hadoop/dfs/name</value>
    </property>

    <!-- WebHDFS -->
    <property>
        <name>dfs.webhdfs.enabled</name>
        <value>true</value>
    </property>

    <!-- Permissions -->
    <property>
        <name>dfs.permissions.superusergroup</name>
        <value>hadoop</value>
    </property>
    <property>
        <name>dfs.permissions.enabled</name>
        <value>false</value>
    </property>

    <!-- Data transfer -->
    <property>
        <name>dfs.client.use.datanode.hostname</name>
        <value>true</value>
    </property>
    <property>
        <name>dfs.datanode.use.datanode.hostname</name>
        <value>true</value>
    </property>
    <property>
        <name>dfs.datanode.hostname</name>
        <value>localhost</value>
    </property>

    <!-- Block size: 128MB -->
    <property>
        <name>dfs.blocksize</name>
        <value>134217728</value>
    </property>

    <!-- NameNode handler threads -->
    <property>
        <name>dfs.namenode.handler.count</name>
        <value>100</value>
    </property>

    <!-- Support append (needed for Delta Lake) -->
    <property>
        <name>dfs.support.append</name>
        <value>true</value>
    </property>

    <!-- Compression -->
    <property>
        <name>dfs.compress.enabled</name>
        <value>true</value>
    </property>
</configuration>
