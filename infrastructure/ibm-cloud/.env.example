# ═══════════════════════════════════════════════════════════════
# Environment Variables — IBM Cloud Medallion Pipeline
# ═══════════════════════════════════════════════════════════════
# Copy to .env and fill in all values.
# Source before running scripts: set -a && source .env && set +a
#
# NEVER commit .env to version control!
# ═══════════════════════════════════════════════════════════════

# ── IBM Cloud Authentication ──
IBMCLOUD_API_KEY=
IBMCLOUD_REGION=us-south
IBMCLOUD_RESOURCE_GROUP=Default

# ── Cloud Object Storage (HMAC credentials) ──
COS_ACCESS_KEY=
COS_SECRET_KEY=
COS_ENDPOINT=s3.us-south.cloud-object-storage.appdomain.cloud
COS_BUCKET_RAW=datalake-raw-us-south
COS_BUCKET_BRONZE=datalake-bronze-us-south
COS_BUCKET_SILVER=datalake-silver-us-south
COS_BUCKET_GOLD=datalake-gold-us-south
COS_BUCKET_JARS=datalake-raw-us-south

# ── IBM Db2 on Cloud ──
DB2_HOSTNAME=
DB2_PORT=30376
DB2_DATABASE=bludb
DB2_USERNAME=
DB2_PASSWORD=
DB2_SSL=true

# ── Analytics Engine Serverless ──
AE_INSTANCE_ID=
AE_REGION=us-south
AE_API_KEY=

# ── IKS Cluster ──
CLUSTER_NAME=medallion-dev-iks
NAMESPACE=spark

# ── Pipeline Configuration ──
EXECUTION_MODE=          # IBM_AE | HDFS | LOCAL (auto-detect if empty)
JAR_NAME=root-assembly-2.0.0.jar
SPARK_VERSION=3.5

# ── Terraform Backend (COS S3 compatible) ──
AWS_ACCESS_KEY_ID=       # Same as COS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=   # Same as COS_SECRET_KEY

# ── Monitoring (optional) ──
SYSDIG_ACCESS_KEY=
LOG_ANALYSIS_INGESTION_KEY=
